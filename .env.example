JANAM_WRITE_API_KEY=replace-with-strong-write-key
JANAM_READ_API_KEY=replace-with-strong-read-key
JANAM_API_KEY=replace-with-strong-write-key

JANAM_ENFORCE_EXPLICIT_KEYS=true

JANAM_CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

JANAM_RATE_LIMIT_WRITE_PER_MINUTE=120
JANAM_RATE_LIMIT_READ_PER_MINUTE=60
JANAM_RETRY_AFTER_WRITE_SECONDS=60
JANAM_RETRY_AFTER_READ_SECONDS=60

# n8n webhook signing for /ingest/n8n
JANAM_N8N_WEBHOOK_SECRET=replace-with-strong-n8n-webhook-secret
JANAM_N8N_WEBHOOK_MAX_SKEW_SECONDS=300

# Anonymous ingest controls (recommended for citizen safety)
JANAM_ANONYMIZE_INGEST=true
JANAM_ANONYMIZATION_SALT=replace-with-strong-anonymization-salt
JANAM_STORE_INGEST_RAW_PAYLOAD=false
JANAM_GPS_ROUND_DECIMALS=3

# Database backend options:
# sqlite (default) or postgres
JANAM_DB_BACKEND=postgres
JANAM_DATABASE_URL=postgresql://postgres:postgres@db:5432/janam